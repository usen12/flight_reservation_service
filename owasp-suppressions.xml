<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        H2 Database — test scope only, never deployed to production.
        Any H2 CVEs are not exploitable in this project since H2 is
        used exclusively for in-memory integration tests via @ActiveProfiles("test").
    -->
    <suppress>
        <notes>H2 is test-scope only — not reachable in production</notes>
        <gav regex="true">^com\.h2database:h2:.*$</gav>
        <cvssBelow>10</cvssBelow>
    </suppress>

</suppressions>
